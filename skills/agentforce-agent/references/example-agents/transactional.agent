# =============================================================================
# TRANSACTIONAL AGENT TEMPLATE
# =============================================================================
# Agent that performs data lookups via Salesforce Flows or Apex.
# NO knowledge base — all answers come from live data queries.
# Replace all {{PLACEHOLDERS}} with actual values before publishing.
#
# KEY PATTERNS:
# - 3-state conditional for data collection: ask -> fetch -> present
# - Actions block with typed inputs/outputs and Flow target
# - Escalation flag pattern to prevent false-positive handoffs
# =============================================================================

config:
   developer_name: "{{AGENT_NAME}}"
   default_agent_user: "{{DEFAULT_AGENT_USER}}"
   agent_label: "{{AGENT_LABEL}}"
   description: "{{DESCRIPTION}}"

variables:
   # NOTE: Only add linked MessagingSession variables if deploying to a
   # messaging channel (WhatsApp, web chat with Messaging). For web-only
   # agents without Messaging configured, linked variables cause
   # "Internal Error" on publish.
   customer_id: mutable string = ""
      description: "Customer identifier collected during conversation"
   lookup_result: mutable string = ""
      description: "Result returned from the data lookup"
   customer_name: mutable string = ""
      description: "Customer name returned from the data lookup"
   escalation_requested: mutable boolean = False
      description: "Whether the user has explicitly asked to speak with a human agent"

system:
   instructions: "You are the virtual assistant of {{COMPANY_NAME}}. Your role is to help customers with {{SERVICE_DESCRIPTION}} via {{CHANNEL}}. ALWAYS respond in {{LANGUAGE}}. Tone: {{TONE_DESCRIPTION}}. When looking up data, always confirm the identifier with the user before querying. Present results clearly and suggest relevant next steps. If a lookup returns no results, offer to try again or suggest alternative channels ({{SELF_SERVICE_CHANNELS}}). Only escalate to a human agent when the user explicitly requests it, never as a first option."
   messages:
      welcome: "{{WELCOME_MESSAGE}}"
      error: "{{ERROR_MESSAGE}}"

language:
   default_locale: "{{LOCALE}}"

start_agent topic_selector:
   label: "Topic Selector"
   description: "Route the user to the appropriate topic based on their message"

   reasoning:
      instructions:|
         Select the tool that best matches the user's message and conversation history. Default to go_to_lookup for any request involving data retrieval or account queries.
      actions:
         go_to_lookup: @utils.transition to @topic.data_lookup
            description: "The user wants to look up, check, or query their {{DATA_TYPE}} (e.g. balance, order status, account details)"
         go_to_escalation: @utils.transition to @topic.escalation
            description: "The user EXPLICITLY asks to speak with a human agent. Do NOT use if the user just has a difficult question."
            available when @variables.escalation_requested == True
         go_to_off_topic: @utils.transition to @topic.off_topic
            description: "The topic is clearly outside the scope of {{COMPANY_NAME}} (e.g. weather, sports, unrelated services)"

   after_reasoning:
      if @variables.escalation_requested == True:
         set @variables.escalation_requested = False

topic data_lookup:
   label: "{{LOOKUP_LABEL}}"
   description: "{{LOOKUP_DESCRIPTION}}"

   actions:
      get_data:
         description: "{{ACTION_DESCRIPTION}}"
         inputs:
            customerId: string
               description: "{{INPUT_DESCRIPTION}}"
         outputs:
            result: string
               description: "{{OUTPUT_RESULT_DESCRIPTION}}"
            customerName: string
               description: "{{OUTPUT_NAME_DESCRIPTION}}"
         target: "flow://{{FLOW_NAME}}"

   reasoning:
      instructions:->
         if @variables.customer_id == "":
            | Ask the user for their {{ID_TYPE}} to perform the lookup.
              Be friendly and explain why you need it.
         if @variables.customer_id != "" and @variables.lookup_result == "":
            run @actions.get_data
               with customerId=@variables.customer_id
               set @variables.lookup_result = @outputs.result
               set @variables.customer_name = @outputs.customerName
         if @variables.lookup_result != "":
            | The customer's name is {!@variables.customer_name}.
              The lookup result is: {!@variables.lookup_result}.
              Present this information in a friendly, clear way.
              Suggest relevant next steps the user might want to take.
      actions:
         capture_id: @utils.setVariables
            description: "Capture the customer's {{ID_TYPE}} from conversation"
            with customer_id=...
         request_asesor: @utils.setVariables
            description: "The user explicitly asks to speak with a human agent"
            with escalation_requested=True

   after_reasoning:
      if @variables.escalation_requested == True:
         transition to @topic.escalation

topic escalation:
   label: "Escalation"
   description: "Transfers to a human agent when the user explicitly requests one"

   reasoning:
      instructions:->
         | The user has asked to speak with a human agent.
           Use a warm farewell message before escalating.
           Then use {!@actions.escalate_to_agent} to transfer.
           If escalation fails, inform the user and offer alternative contact
           methods such as {{FALLBACK_CONTACT_METHODS}}.
      actions:
         escalate_to_agent: @utils.escalate
            description: "Transfer the conversation to a human agent"

   after_reasoning:
      set @variables.escalation_requested = False

topic off_topic:
   label: "Off Topic"
   description: "Redirects the conversation when the user asks questions outside the business scope"

   reasoning:
      instructions:->
         | Redirect the conversation politely and briefly.
           Do not answer general knowledge questions.
           Only respond to general greetings and questions about your capabilities.
           Suggest the user ask about {{SUGGESTED_TOPICS}}.
