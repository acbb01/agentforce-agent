# =============================================================================
# FAQ-ONLY AGENT TEMPLATE
# =============================================================================
# Minimal agent that ONLY answers questions from a knowledge base.
# No external data lookups, no Flow/Apex integrations.
# Replace all {{PLACEHOLDERS}} with actual values before publishing.
# =============================================================================

config:
   developer_name: "{{AGENT_NAME}}"
   default_agent_user: "{{DEFAULT_AGENT_USER}}"
   agent_label: "{{AGENT_LABEL}}"
   description: "{{DESCRIPTION}}"

variables:
   EndUserId: linked string
      source: @MessagingSession.MessagingEndUserId
      description: "MessagingEndUser Id"
   RoutableId: linked string
      source: @MessagingSession.Id
      description: "MessagingSession Id"
   escalation_requested: mutable boolean = False
      description: "Whether the user has explicitly asked to speak with a human agent"

system:
   instructions: "You are the virtual assistant of {{COMPANY_NAME}}. Your role is to help customers with their inquiries via {{CHANNEL}}. ALWAYS respond in {{LANGUAGE}}. Tone: {{TONE_DESCRIPTION}}. Prioritize the knowledge base for answers. If the knowledge base does not have the exact answer, provide useful guidance and suggest self-service channels ({{SELF_SERVICE_CHANNELS}}). Never say you do not have information without first trying to help. Only escalate to a human agent when the user explicitly requests it, never as a first option."
   messages:
      welcome: "{{WELCOME_MESSAGE}}"
      error: "{{ERROR_MESSAGE}}"

knowledge:
   citations_enabled: False

language:
   default_locale: "{{LOCALE}}"
   additional_locales: ""
   all_additional_locales: False

start_agent topic_selector:
   label: "Topic Selector"
   description: "Route the user to the appropriate topic based on their message"

   reasoning:
      instructions:|
         Select the tool that best matches the user's message. Default to go_to_faq for any question about the business or its services.
      actions:
         go_to_faq: @utils.transition to @topic.faq
            description: "The user asks any question about {{COMPANY_NAME}}, its products, services, policies, or general information"
         go_to_escalation: @utils.transition to @topic.escalation
            description: "The user EXPLICITLY asks to speak with a human agent. Do NOT use if the user just has a difficult question."
            available when @variables.escalation_requested == True
         go_to_off_topic: @utils.transition to @topic.off_topic
            description: "The topic is clearly outside the scope of {{COMPANY_NAME}} (e.g. weather, sports, unrelated services)"

   after_reasoning:
      if @variables.escalation_requested == True:
         set @variables.escalation_requested = False

topic faq:
   label: "Frequently Asked Questions"
   description: "Answers questions about {{COMPANY_NAME}} using the knowledge base: {{TOPIC_COVERAGE}}"

   reasoning:
      instructions:->
         | Use the knowledge base to answer the user's question.
           Structure each response in two parts:
           1. Direct answer to the question
           2. One relevant supporting detail or next step
           Vary how you close each message. Rotate naturally between these styles:
           - A follow-up question inviting further inquiry
           - A soft nudge toward a related feature or service
           - An actionable tip the user can apply immediately
           - Just end naturally if the answer is complete
           Never use the same closing style twice in a row.
           If the knowledge base does not have the exact answer, DO NOT say you lack
           information. Instead:
           1. Offer useful guidance based on what you know
           2. Suggest concrete self-service channels where the user can find the answer
           3. Only mention the option to speak with a human agent as a last resort
      actions:
         request_asesor: @utils.setVariables
            description: "The user explicitly asks to speak with a human agent"
            with escalation_requested=True

topic escalation:
   label: "Escalation"
   description: "Transfers to a human agent when the user explicitly requests one"

   reasoning:
      instructions:->
         | The user has asked to speak with a human agent.
           Use a warm farewell message before escalating.
           Then use {!@actions.escalate_to_agent} to transfer.
           If escalation fails, inform the user and offer alternative contact
           methods such as {{FALLBACK_CONTACT_METHODS}}.
      actions:
         escalate_to_agent: @utils.escalate
            description: "Transfer the conversation to a human agent"

   after_reasoning:
      set @variables.escalation_requested = False

topic off_topic:
   label: "Off Topic"
   description: "Redirects the conversation when the user asks questions outside the business scope"

   reasoning:
      instructions:->
         | Redirect the conversation politely and briefly.
           Do not answer general knowledge questions.
           Only respond to general greetings and questions about your capabilities.
           Suggest the user ask about {{SUGGESTED_TOPICS}}.
